# =========================================================
# InvoiceApp — Environment Variables (TEMPLATE)
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية.
# لا تضع أي أسرار حقيقية في هذا الملف — يُرفع للمستودع العام.
# =========================================================

# Flask Security — ولّد مفتاحاً قوياً: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_random_64_char_hex

# Admin Login Credentials
ADMIN_USERNAME=your_admin_username
MASTER_PASSWORD=change_me_strong_password

# Database (PostgreSQL في الإنتاج). اتركه فارغاً محلياً لاستخدام SQLite.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (SMTP - Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_gmail_app_password

# GPS Cockpit
GPS_ASSET_URL=https://fleetmanagement-api-clust03.gpscockpit.com/api/asset
GPS_TOKEN=your_gps_api_token

# Gemini AI assistant (Google Generative Language). Set the REAL value on the host env only.
# مفتاح المساعد الذكي — يُضبط في بيئة الخادم فقط، ولا يُرسل للمتصفح أبداً.
GEMINI_API_KEY=your_google_ai_studio_key_here
# اختياري: ترتيب نماذج البديل عند الضغط (افتراضي مناسب)
# GEMINI_MODELS=gemini-flash-latest,gemini-flash-lite-latest,gemini-2.0-flash
# ملاحظة: حدود استهلاك المساعد محسوبة في ذاكرة العملية — شغّل عاملاً واحداً
# (gunicorn --workers 1 --threads 8) حتى يبقى الحد العام دقيقاً.
