# =========================================================
# InvoiceApp - Environment Variables Template
# Copy this file to .env and fill in your actual values.
# =========================================================

# Flask Security (Generate a strong random string)
SECRET_KEY=your_secure_secret_key_here

# Master Password for direct login
MASTER_PASSWORD=your_master_password_here

# Google OAuth (optional - leave blank if not using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP - Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# GPS Cockpit
GPS_USER=your_gps_username
GPS_PASS=your_gps_password
GPS_ASSET_URL=https://fleetmanagement-api-clust03.gpscockpit.com/api/asset
GPS_PERMANENT_TOKEN=WUTOWPHXLQFTFIUOVBONDTOPVULUPVLM
